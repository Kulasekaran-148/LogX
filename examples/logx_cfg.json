{
  "name": "Appname",
  "logfile_path": "./logx.log",
  "enable_console_logging": 1,
  "enable_file_logging": 1,
  "enable_colored_logs": 1,
  "use_tty_detection": 1,
  "console_level": "TRACE",
  "file_level": "TRACE",
  "rotate_type": "BY_SIZE",
  "max_logfile_size_mb": 10,
  "max_logfile_backups": 3,
  "rotate_after_days": 1,
  "compress": 0,
  "delay_compress": 0,
  "banner_pattern": "=-",
  "print_config": 1,
  "timestamp_format": "LOCAL"
}
